---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section class="section section-register" id="register">
  <div class="container register-inner">
    <h2 class="register-title">{t.register.title}</h2>
    <p class="register-desc">{t.register.desc}</p>
    <div class="register-actions">
      <a href={t.register.primaryHref} target="_blank" rel="noopener" class="btn btn-primary btn-lg">
        {t.register.btn}
      </a>
      <a href={t.register.officialHref} target="_blank" rel="noopener" class="btn btn-ghost-light btn-lg">
        {t.nav.official}
      </a>
      <a href={t.register.kktixHref} target="_blank" rel="noopener" class="btn btn-ghost-light btn-lg">
        {t.register.btnAlt}
      </a>
    </div>
    <p class="register-note">{t.register.note}</p>
  </div>
</section>

<style>
  .container {
    max-width: 68.75rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .section { padding: 6rem 0; }
  .section-register {
    background: linear-gradient(135deg, #00257A 0%, #003DA5 60%, #0054A6 100%);
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
  }
  .section-register::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 90% 50%, rgba(0,153,214,0.25), transparent);
  }
  .register-inner { position: relative; text-align: center; }
  .register-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .register-desc {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.75);
    max-width: 32.5rem;
    margin: 0 auto 2.25rem;
    line-height: 1.7;
  }
  .register-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 1.5rem;
  }
  .register-note { color: rgba(255,255,255,0.5); font-size: 0.88rem; }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    border-radius: 0.625rem;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
    border: none;
  }
  .btn:hover { transform: translateY(-0.0625rem); }
  .btn-primary {
    background: var(--blue-light);
    color: #fff;
    box-shadow: 0 0.25rem 1rem rgba(0,153,214,0.4);
  }
  .btn-primary:hover { background: #00b3f0; box-shadow: 0 0.375rem 1.25rem rgba(0,153,214,0.5); }
  .btn-ghost-light {
    background: transparent;
    color: #fff;
    border: 0.09375rem solid rgba(255,255,255,0.5);
  }
  .btn-ghost-light:hover { background: rgba(255,255,255,0.1); }
  .btn-lg { padding: 1rem 2.25rem; font-size: 1rem; border-radius: 0.75rem; }
</style>
