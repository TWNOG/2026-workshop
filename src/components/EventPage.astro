---
import type { Lang, Translations } from '../i18n/translations';
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

import Nav from './Nav.astro';
import Hero from './Hero.astro';
import About from './About.astro';
import PhotoMarquee from './PhotoMarquee.astro';
import Course from './Course.astro';
import Schedule from './Schedule.astro';
import Venue from './Venue.astro';
import Organizers from './Organizers.astro';
import Register from './Register.astro';
import Footer from './Footer.astro';

interface Props {
  lang: Lang;
  t: Translations;
}

const { lang, t } = Astro.props;
const otherLang = lang === 'zh' ? 'en' : 'zh';
const otherLangLabel = lang === 'zh' ? 'EN' : '中文';
const otherLangHref = lang === 'zh' ? '/en/' : '/';

// photo slot widths (px) — 8 unique sizes
const strip1Widths = [360, 210, 300, 240, 400, 220, 340, 260];
const strip2Widths = [280, 380, 220, 310, 250, 360, 200, 330];

// Get all .webp images from public/img
const imgDir = path.join(process.cwd(), 'public/img');
const imgFiles = fs.readdirSync(imgDir).filter(f => f.endsWith('.webp'));
const images = imgFiles.map(f => `/img/${f}`);

// Helper to get random subset/repeat of images
function getRandomImgs(count: number) {
  let result: string[] = [];
  while (result.length < count) {
    const shuffled = [...images].sort(() => Math.random() - 0.5);
    result = [...result, ...shuffled];
  }
  return result.slice(0, count);
}

const strip1Imgs = getRandomImgs(strip1Widths.length * 2);
const strip2Imgs = getRandomImgs(strip2Widths.length * 2);
---

<Layout title={t.siteTitle} description={t.siteDescription} lang={t.lang}>

  <Nav 
    t={t} 
    otherLangHref={otherLangHref} 
    otherLangLabel={otherLangLabel} 
    otherLang={otherLang} 
  />

  <Hero t={t} />

  <About t={t} />

  <PhotoMarquee 
    images={strip1Imgs} 
    widths={strip1Widths} 
    direction="left" 
    variant="white" 
  />

  <Course t={t} />

  <Schedule t={t} />

  <PhotoMarquee 
    images={strip2Imgs} 
    widths={strip2Widths} 
    direction="right" 
    variant="alt" 
  />

  <Venue t={t} />

  <Organizers t={t} />

  <Register t={t} />

  <Footer 
    t={t} 
    otherLangHref={otherLangHref} 
    otherLangLabel={otherLangLabel} 
  />

</Layout>
