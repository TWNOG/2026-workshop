---
import type { Lang, Translations } from '../i18n/translations';
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  lang: Lang;
  t: Translations;
}

const { lang, t } = Astro.props;
const otherLang = lang === 'zh' ? 'en' : 'zh';
const otherLangLabel = lang === 'zh' ? 'EN' : '中文';
const otherLangHref = lang === 'zh' ? '/en/' : '/';

// photo slot widths (px) — 8 unique sizes
const strip1 = [360, 210, 300, 240, 400, 220, 340, 260];
const strip2 = [280, 380, 220, 310, 250, 360, 200, 330];

// Get all .webp images from public/img
const imgDir = path.join(process.cwd(), 'public/img');
const imgFiles = fs.readdirSync(imgDir).filter(f => f.endsWith('.webp'));
const images = imgFiles.map(f => `/img/${f}`);

// Helper to get random subset/repeat of images
function getRandomImgs(count: number) {
  let result: string[] = [];
  while (result.length < count) {
    const shuffled = [...images].sort(() => Math.random() - 0.5);
    result = [...result, ...shuffled];
  }
  return result.slice(0, count);
}

const strip1Imgs = getRandomImgs(strip1.length * 2);
const strip2Imgs = getRandomImgs(strip2.length * 2);
---

<Layout title={t.siteTitle} description={t.siteDescription} lang={t.lang}>

  <!-- Nav -->
  <nav class="nav">
    <div class="container nav-inner">
      <div class="nav-brand">
        <span class="brand-apnic">APNIC</span>
        <span class="brand-sep">×</span>
        <span class="brand-twnog">TWNOG 7</span>
      </div>
      <ul class="nav-links" id="nav-links">
        <li><a href="#about">{t.nav.about}</a></li>
        <li><a href="#schedule">{t.nav.schedule}</a></li>
        <li><a href="#speakers">{t.nav.speakers}</a></li>
        <li><a href="#venue">{t.nav.venue}</a></li>
        <li>
          <a href={otherLangHref} class="lang-toggle" aria-label={`Switch to ${otherLang}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            {otherLangLabel}
          </a>
        </li>
        <li><a href="#register" class="nav-cta">{t.nav.register}</a></li>
      </ul>
      <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <div class="hero-badges">
        <span class="badge">{t.hero.badge1}</span>
        <span class="badge badge-outline">{t.hero.badge2}</span>
      </div>
      <h1 class="hero-title">
        {t.hero.title}<br /><span class="hero-title-accent">{t.hero.titleAccent}</span>
      </h1>
      <p class="hero-subtitle">
        {t.hero.subtitle.split('\n').map((line, i) => (
          <>{line}{i === 0 && <br />}</>
        ))}
      </p>
      <div class="hero-meta">
        <div class="hero-meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span>{t.hero.metaDate}</span>
        </div>
        <div class="hero-meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>{t.hero.metaVenue}</span>
        </div>
      </div>
      <div class="hero-actions">
        <a href="#register" class="btn btn-primary">{t.hero.registerBtn}</a>
        <a href="#schedule" class="btn btn-ghost">{t.hero.scheduleBtn}</a>
      </div>
    </div>
    <div class="hero-wave">
      <!-- back layer: slowest, semi-transparent -->
      <div class="wave-track wave-track-1">
        <svg viewBox="0 0 1440 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,55 C240,15 480,80 720,45 C960,10 1200,75 1440,55 L1440,90 L0,90 Z" fill="rgba(255,255,255,0.2)"/></svg>
        <svg viewBox="0 0 1440 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,55 C240,15 480,80 720,45 C960,10 1200,75 1440,55 L1440,90 L0,90 Z" fill="rgba(255,255,255,0.2)"/></svg>
      </div>
      <!-- mid layer: medium speed, more opaque -->
      <div class="wave-track wave-track-2">
        <svg viewBox="0 0 1440 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,45 C360,85 720,10 1080,60 C1260,80 1380,30 1440,45 L1440,90 L0,90 Z" fill="rgba(255,255,255,0.45)"/></svg>
        <svg viewBox="0 0 1440 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,45 C360,85 720,10 1080,60 C1260,80 1380,30 1440,45 L1440,90 L0,90 Z" fill="rgba(255,255,255,0.45)"/></svg>
      </div>
      <!-- front layer: fastest, solid white — defines the clean edge -->
      <div class="wave-track wave-track-3">
        <svg viewBox="0 0 1440 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,40 C280,80 560,5 840,50 C1120,90 1300,20 1440,40 L1440,90 L0,90 Z" fill="#FFFFFF"/></svg>
        <svg viewBox="0 0 1440 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,40 C280,80 560,5 840,50 C1120,90 1300,20 1440,40 L1440,90 L0,90 Z" fill="#FFFFFF"/></svg>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="section" id="about">
    <div class="container">
      <div class="section-header">
        <span class="section-label">{t.about.label}</span>
        <h2 class="section-title">{t.about.title}</h2>
      </div>
      <div class="about-grid">
        <div class="about-text">
          <p set:html={t.about.p1} />
          <p>{t.about.p2}</p>
          <p>{t.about.p3}</p>
          <div class="about-tags">
            <span class="tag">BGP</span>
            <span class="tag">IPv6</span>
            <span class="tag">Routing Policy</span>
            <span class="tag">Network Security</span>
            <span class="tag">RPKI</span>
            <span class="tag">Multihoming</span>
          </div>
        </div>
        <div class="about-stats">
          <div class="stat-card">
            <div class="stat-number">3</div>
            <div class="stat-label">{t.about.stats.days}</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">30</div>
            <div class="stat-label">{t.about.stats.participants}</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">4</div>
            <div class="stat-label">{t.about.stats.topics}</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">100%</div>
            <div class="stat-label">{t.about.stats.labs}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Marquee strip 1 -->
  <div class="photo-marquee marquee-on-white">
    <div class="marquee-track marquee-left">
      {strip1Imgs.map((src, i) => (
        <div class="marquee-item" style={`width:${strip1[i % strip1.length]}px`}>
          <img src={src} alt="" loading="lazy" />
        </div>
      ))}
    </div>
  </div>

  <!-- Schedule -->
  <section class="section section-alt" id="schedule">
    <div class="container">
      <div class="section-header">
        <span class="section-label">{t.schedule.label}</span>
        <h2 class="section-title">{t.schedule.title}</h2>
      </div>
      <div class="schedule-tabs">
        {t.schedule.days.map((day) => (
          <div class="schedule-day">
            <div class="day-header">
              <span class="day-badge">{day.badge}</span>
              <h3>{day.heading}</h3>
            </div>
            <div class="schedule-items">
              {day.items.map((item) => (
                <div class="schedule-item">
                  <span class="time">{item.time}</span>
                  <div class="schedule-content">
                    <strong>{item.title}</strong>
                    <p>{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Speakers -->
  <section class="section" id="speakers">
    <div class="container">
      <div class="section-header">
        <span class="section-label">{t.speakers.label}</span>
        <h2 class="section-title">{t.speakers.title}</h2>
      </div>
      <div class="speakers-list">
        {t.speakers.people.map((person) => (
          <div class="speaker-card">
            <div class="speaker-right">
              <div class="speaker-id">
                <div class="speaker-name-row">
                  <h3 class="speaker-name">{person.name}</h3>
                  <span class="speaker-org">{person.org}</span>
                </div>
                <p class="speaker-role">{person.role}</p>
              </div>
              <div class="speaker-highlights">
                {person.highlights.map((h) => (
                  <div class="speaker-highlight">
                    <span class="highlight-value">{h.value}</span>
                    <span class="highlight-label">{h.label}</span>
                  </div>
                ))}
              </div>
              <div class="speaker-bio">
                {person.details.map((para) => <p>{para}</p>)}
              </div>
              <div class="speaker-tags">
                {person.tags.map((tag) => <span class="tag tag-sm">{tag}</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Marquee strip 2 -->
  <div class="photo-marquee marquee-on-alt">
    <div class="marquee-track marquee-right">
      {strip2Imgs.map((src, i) => (
        <div class="marquee-item" style={`width:${strip2[i % strip2.length]}px`}>
          <img src={src} alt="" loading="lazy" />
        </div>
      ))}
    </div>
  </div>

  <!-- Venue -->
  <section class="section" id="venue">
    <div class="container">
      <div class="section-header">
        <span class="section-label">{t.venue.label}</span>
        <h2 class="section-title">{t.venue.title}</h2>
      </div>
      <div class="venue-grid">
        <div class="venue-info">
          <div class="venue-card">
            <h3>{t.venue.name}</h3>
            <p class="venue-address">{t.venue.address}</p>
            <div class="venue-details">
              <div class="venue-detail">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                <span>{t.venue.transport1}</span>
              </div>
              <div class="venue-detail">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span>{t.venue.transport2}</span>
              </div>
            </div>
          </div>
        </div>
        <div class="venue-map">
          <div class="map-embed-wrap">
            <iframe
              src="https://maps.google.com/maps?q=25.04328,121.52867&hl=zh-TW&z=16&output=embed"
              title={t.venue.name}
              loading="lazy"
              allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
          <a
            href="https://maps.google.com/?q=NTUH+International+Convention+Center+Taipei"
            target="_blank"
            rel="noopener"
            class="map-link-ext"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            {t.venue.mapLink}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Organizers -->
  <section class="section section-alt" id="organizers">
    <div class="container">
      <div class="section-header">
        <span class="section-label">{t.organizers.label}</span>
        <h2 class="section-title">{t.organizers.title}</h2>
      </div>
      <div class="org-grid">
        {t.organizers.orgs.map((org) => (
          <div class="org-card">
            <div class="org-logo-wrap">
              <img src={`/org/${org.color}.svg`} alt={org.abbr} class="org-logo-img" />
            </div>
            <p>{org.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Register -->
  <section class="section section-register" id="register">
    <div class="container register-inner">
      <h2 class="register-title">{t.register.title}</h2>
      <p class="register-desc">{t.register.desc}</p>
      <div class="register-actions">
        <a href="https://twnog.kktix.cc/events/2026twnog7" target="_blank" rel="noopener" class="btn btn-primary btn-lg">
          {t.register.btn}
        </a>
        <a href="https://2026.twnog.net/" target="_blank" rel="noopener" class="btn btn-ghost-light btn-lg">
          {t.register.btnAlt}
        </a>
      </div>
      <p class="register-note">{t.register.note}</p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="brand-apnic">APNIC</span>
        <span class="brand-sep">×</span>
        <span class="brand-twnog">TWNOG 7</span>
        <span class="footer-year">· 2026</span>
      </div>
      <div class="footer-links">
        <a href="https://academy.apnic.net" target="_blank" rel="noopener">APNIC Academy</a>
        <a href="https://2026.twnog.net" target="_blank" rel="noopener">TWNOG 7</a>
        <a href="https://twnog.kktix.cc" target="_blank" rel="noopener">KKTIX</a>
        <a href={otherLangHref}>{otherLangLabel}</a>
      </div>
      <p class="footer-copy">{t.footer.copy}</p>
    </div>
  </footer>

</Layout>

<script>
  const btn = document.getElementById('nav-hamburger');
  const menu = document.getElementById('nav-links');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
    // close on any nav link click
    menu.querySelectorAll('a').forEach(a =>
      a.addEventListener('click', () => {
        menu.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      })
    );
  }
</script>

<style>
  /* ── Layout ── */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Nav ── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(0, 37, 122, 0.97);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }
  .brand-apnic { color: #fff; }
  .brand-sep { color: rgba(255,255,255,0.4); }
  .brand-twnog { color: #7EC8E3; }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
  }
  .nav-links a {
    padding: 6px 14px;
    border-radius: 8px;
    color: rgba(255,255,255,0.8);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s, background 0.2s;
  }
  .nav-links a:hover { color: #fff; background: rgba(255,255,255,0.1); }
  .lang-toggle {
    display: flex !important;
    align-items: center;
    gap: 5px;
    border: 1px solid rgba(255,255,255,0.25) !important;
    font-size: 0.8rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.04em;
  }
  .lang-toggle:hover { border-color: rgba(255,255,255,0.6) !important; }
  .nav-cta {
    background: var(--blue-light) !important;
    color: #fff !important;
    font-weight: 600 !important;
  }
  .nav-cta:hover { background: #00b3f0 !important; }

  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #00257A 0%, #003DA5 50%, #0054A6 100%);
    overflow: hidden;
    padding-top: 64px;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 80% 20%, rgba(0,153,214,0.25) 0%, transparent 60%),
      radial-gradient(ellipse 40% 60% at 10% 80%, rgba(0,80,160,0.4) 0%, transparent 60%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    padding: 80px 24px;
  }
  .hero-badges {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 24px;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 14px;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: var(--blue-light);
    color: #fff;
  }
  .badge-outline {
    background: transparent;
    border: 1.5px solid rgba(255,255,255,0.4);
    color: rgba(255,255,255,0.9);
  }
  .hero-title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 800;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }
  .hero-title-accent { color: #7EC8E3; }
  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255,255,255,0.75);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 40px;
  }
  .hero-meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
    font-weight: 500;
  }
  .hero-meta-item svg { flex-shrink: 0; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; }
  .hero-wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 90px;
    overflow: hidden;
  }
  .wave-track {
    position: absolute;
    bottom: 0;
    display: flex;
    width: 200%;
  }
  .wave-track svg {
    width: 50%;
    height: 90px;
    display: block;
    flex-shrink: 0;
  }
  .wave-track-1 { animation: wave-scroll 18s linear infinite; }
  .wave-track-2 { animation: wave-scroll 11s linear infinite reverse; }
  .wave-track-3 { animation: wave-scroll 7s linear infinite; }

  @keyframes wave-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 12px 28px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
    border: none;
  }
  .btn:hover { transform: translateY(-1px); }
  .btn-primary {
    background: var(--blue-light);
    color: #fff;
    box-shadow: 0 4px 16px rgba(0,153,214,0.4);
  }
  .btn-primary:hover { background: #00b3f0; box-shadow: 0 6px 20px rgba(0,153,214,0.5); }
  .btn-ghost {
    background: rgba(255,255,255,0.12);
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.3);
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.2); }
  .btn-ghost-light {
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.5);
  }
  .btn-ghost-light:hover { background: rgba(255,255,255,0.1); }
  .btn-lg { padding: 16px 36px; font-size: 1rem; border-radius: 12px; }

  /* ── Sections ── */
  .section { padding: 96px 0; }
  .section-alt { background: var(--bg-alt); }
  .section-header { text-align: center; margin-bottom: 64px; }
  .section-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blue-light);
    margin-bottom: 12px;
  }
  .section-title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--blue-dark);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .section-desc { margin-top: 12px; color: var(--text-muted); font-size: 1.05rem; }

  /* ── About ── */
  .about-grid {
