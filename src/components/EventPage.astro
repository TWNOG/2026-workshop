---
import type { Lang, Translations } from '../i18n/translations';
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  lang: Lang;
  t: Translations;
}

const { lang, t } = Astro.props;
const otherLang = lang === 'zh' ? 'en' : 'zh';
const otherLangLabel = lang === 'zh' ? 'EN' : '中文';
const otherLangHref = lang === 'zh' ? '/en/' : '/';

// photo slot widths (px) — 8 unique sizes
const strip1 = [360, 210, 300, 240, 400, 220, 340, 260];
const strip2 = [280, 380, 220, 310, 250, 360, 200, 330];

// Get all .webp images from public/img
const imgDir = path.join(process.cwd(), 'public/img');
const imgFiles = fs.readdirSync(imgDir).filter(f => f.endsWith('.webp'));
const images = imgFiles.map(f => `/img/${f}`);

// Helper to get random subset/repeat of images
function getRandomImgs(count: number) {
  let result: string[] = [];
  while (result.length < count) {
    const shuffled = [...images].sort(() => Math.random() - 0.5);
    result = [...result, ...shuffled];
  }
  return result.slice(0, count);
}

const strip1Imgs = getRandomImgs(strip1.length * 2);
const strip2Imgs = getRandomImgs(strip2.length * 2);
---

<Layout title={t.siteTitle} description={t.siteDescription} lang={t.lang}>

  <!-- Nav -->
  <nav class="nav">
    <div class="container nav-inner">
      <div class="nav-brand">
        <span class="brand-apnic">APNIC</span>
        <span class="brand-sep">×</span>
        <span class="brand-twnog">TWNOG 7</span>
      </div>
      <ul class="nav-links" id="nav-links">
        <li><a href="#about">{t.nav.about}</a></li>
        <li><a href="#course">{t.nav.course}</a></li>
        <li><a href="#venue">{t.nav.venue}</a></li>
        <li>
          <a href={otherLangHref} class="lang-toggle" aria-label={`Switch to ${otherLang}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            {otherLangLabel}
          </a>
        </li>
        <li>
          <a href={t.register.kktixHref} class="nav-cta" target="_blank" rel="noopener">
            {t.nav.register}
          </a>
        </li>
      </ul>
      <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <div class="hero-badges">
        <span class="badge">{t.hero.badge1}</span>
        <span class="badge badge-outline">{t.hero.badge2}</span>
      </div>
      <h1 class="hero-title">
        {t.hero.title}<br /><span class="hero-title-accent">{t.hero.titleAccent}</span>
      </h1>
      <p class="hero-subtitle">
        {t.hero.subtitle.split('\n').map((line, i) => (
          <>{line}{i === 0 && <br />}</>
        ))}
      </p>
      <div class="hero-meta">
        <div class="hero-meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span>{t.hero.metaDate}</span>
        </div>
        <div class="hero-meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>{t.hero.metaVenue}</span>
        </div>
      </div>
      <div class="hero-actions">
        <a href={t.register.kktixHref} target="_blank" rel="noopener" class="btn btn-primary">{t.hero.registerBtn}</a>
        <a href="#schedule" class="btn btn-ghost-light">{t.hero.scheduleBtn}</a>
        <a href={t.register.officialHref} target="_blank" rel="noopener" class="btn btn-ghost-light">{t.nav.official}</a>
      </div>
    </div>
    <div class="hero-wave">
      <!-- back layer: slowest, semi-transparent -->
      <div class="wave-track wave-track-1">
        <svg viewBox="0 0 1440 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,55 C240,15 480,80 720,45 C960,10 1200,75 1440,55 L1440,90 L0,90 Z" fill="rgba(255,255,255,0.2)"/></svg>
        <svg viewBox="0 0 1440 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,55 C240,15 480,80 720,45 C960,10 1200,75 1440,55 L1440,90 L0,90 Z" fill="rgba(255,255,255,0.2)"/></svg>
      </div>
      <!-- mid layer: medium speed, more opaque -->
      <div class="wave-track wave-track-2">
        <svg viewBox="0 0 1440 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,45 C360,85 720,10 1080,60 C1260,80 1380,30 1440,45 L1440,90 L0,90 Z" fill="rgba(255,255,255,0.45)"/></svg>
        <svg viewBox="0 0 1440 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,45 C360,85 720,10 1080,60 C1260,80 1380,30 1440,45 L1440,90 L0,90 Z" fill="rgba(255,255,255,0.45)"/></svg>
      </div>
      <!-- front layer: fastest, solid white — defines the clean edge -->
      <div class="wave-track wave-track-3">
        <svg viewBox="0 0 1440 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,40 C280,80 560,5 840,50 C1120,90 1300,20 1440,40 L1440,90 L0,90 Z" fill="#FFFFFF"/></svg>
        <svg viewBox="0 0 1440 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,40 C280,80 560,5 840,50 C1120,90 1300,20 1440,40 L1440,90 L0,90 Z" fill="#FFFFFF"/></svg>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="section" id="about">
    <div class="container">
      <div class="section-header">
        <span class="section-label">{t.about.label}</span>
        <h2 class="section-title">{t.about.title}</h2>
      </div>
      <div class="about-text">
        <p set:html={t.about.p1} />
        <p>{t.about.p2}</p>
        <p>{t.about.p3}</p>
        <div class="about-tags">
          {t.about.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </div>
    </div>
  </section>

  <!-- Marquee strip 1 -->
  <div class="photo-marquee marquee-on-white">
    <div class="marquee-track marquee-left">
      {strip1Imgs.map((src, i) => (
        <div class="marquee-item" style={`width:${strip1[i % strip1.length] / 16}rem`}>
          <img src={src} alt="" loading="lazy" />
        </div>
      ))}
    </div>
  </div>

  <!-- Course Content -->
  <section class="section" id="course">
    <div class="container">
      <div class="section-header">
        <span class="section-label">{t.course.label}</span>
        <h2 class="section-title">{t.course.title}</h2>
        <p class="section-desc">{t.course.description}</p>
      </div>
      <div class="course-grid">
        <div class="course-card">
          <div class="course-card-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            <h3>{t.course.objectives.title}</h3>
          </div>
          <ul class="course-list">
            {t.course.objectives.items.map(item => <li>{item}</li>)}
          </ul>
        </div>
        <div class="course-card">
          <div class="course-card-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            <h3>{t.course.outline.title}</h3>
          </div>
          <ul class="course-list">
            {t.course.outline.items.map(item => <li>{item}</li>)}
          </ul>
        </div>
        <div class="course-card">
          <div class="course-card-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <h3>{t.course.audience.title}</h3>
          </div>
          <ul class="course-list">
            {t.course.audience.items.map(item => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Schedule -->
  <section class="section section-alt" id="schedule">
    <div class="container">
      <div class="section-header">
        <span class="section-label">{t.schedule.label}</span>
        <h2 class="section-title">{t.schedule.title}</h2>
      </div>
      
      <div class="schedule-tabs-nav">
        {t.schedule.days.map((day, idx) => (
          <button 
            class={`tab-btn ${idx === 0 ? 'active' : ''}`} 
            data-day={idx}
          >
            <span class="tab-day">{day.dayName}</span>
            <span class="tab-date">{day.date.split('/')[1]}/{day.date.split('/')[2]}</span>
          </button>
        ))}
      </div>

      <div class="schedule-content-wrap">
        {t.schedule.days.map((day, idx) => (
          <div 
            class={`schedule-day-pane ${idx === 0 ? 'active' : ''}`} 
            id={`day-pane-${idx}`}
          >
            <div class="schedule-items-list">
              {day.items.map((item) => (
                <div class="schedule-entry">
                  <div class="entry-time">{item.time}</div>
                  <div class="entry-detail">
                    <div class="entry-title">{item.title}</div>
                    {item.speaker && (
                      <div class="entry-speaker">
                        {item.speaker} <span class="speaker-role">· {item.speakerTitle}</span>
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Marquee strip 2 -->
  <div class="photo-marquee marquee-on-alt">
    <div class="marquee-track marquee-right">
      {strip2Imgs.map((src, i) => (
        <div class="marquee-item" style={`width:${strip2[i % strip2.length] / 16}rem`}>
          <img src={src} alt="" loading="lazy" />
        </div>
      ))}
    </div>
  </div>

  <!-- Venue -->
  <section class="section" id="venue">
    <div class="container">
      <div class="section-header">
        <span class="section-label">{t.venue.label}</span>
        <h2 class="section-title">{t.venue.title}</h2>
      </div>
      <div class="venue-grid">
        <div class="venue-info">
          <div class="venue-card">
            <h3>{t.venue.name}</h3>
            <p class="venue-address">{t.venue.address}</p>
            <div class="venue-details">
              <div class="venue-detail">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                <span>{t.venue.transport1}</span>
              </div>
              <div class="venue-detail">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span>{t.venue.transport2}</span>
              </div>
            </div>
          </div>
        </div>
        <div class="venue-map">
          <div class="map-embed-wrap">
            <iframe
              src="https://maps.google.com/maps?q=25.0408601,121.5206807&hl=zh-TW&z=16&output=embed"
              title={t.venue.name}
              loading="lazy"
              allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
          <a
            href="https://www.google.com/maps/search/?api=1&query=25.0408601%2C121.5206807"
            target="_blank"
            rel="noopener"
            class="map-link-ext"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            {t.venue.mapLink}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Organizers -->
  <section class="section section-alt" id="organizers">
    <div class="container">
      <div class="section-header">
        <span class="section-label">{t.organizers.label}</span>
        <h2 class="section-title">{t.organizers.title}</h2>
      </div>
      <div class="org-grid">
        {t.organizers.orgs.map((org) => (
          <div class="org-card">
            <div class="org-logo-wrap">
              <img src={`/org/${org.color}.svg`} alt={org.abbr} class="org-logo-img" />
            </div>
            <p>{org.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Register -->
  <section class="section section-register" id="register">
    <div class="container register-inner">
      <h2 class="register-title">{t.register.title}</h2>
      <p class="register-desc">{t.register.desc}</p>
      <div class="register-actions">
        <a href={t.register.primaryHref} target="_blank" rel="noopener" class="btn btn-primary btn-lg">
          {t.register.btn}
        </a>
        <a href={t.register.officialHref} target="_blank" rel="noopener" class="btn btn-ghost-light btn-lg">
          {t.nav.official}
        </a>
        <a href={t.register.kktixHref} target="_blank" rel="noopener" class="btn btn-ghost-light btn-lg">
          {t.register.btnAlt}
        </a>
      </div>
      <p class="register-note">{t.register.note}</p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="brand-apnic">APNIC</span>
        <span class="brand-sep">×</span>
        <span class="brand-twnog">TWNOG 7</span>
        <span class="footer-year">· 2026</span>
      </div>
      <div class="footer-links">
        <a href="https://academy.apnic.net/en/events?id=a0BOc000003Mh1NMAS" target="_blank" rel="noopener">APNIC Academy</a>
        <a href={t.register.officialHref} target="_blank" rel="noopener">{t.nav.official}</a>
        <a href={t.register.kktixHref} target="_blank" rel="noopener">KKTIX</a>
        <a href={otherLangHref}>{otherLangLabel}</a>
      </div>
      <p class="footer-copy">{t.footer.copy}</p>
    </div>
  </footer>

</Layout>

<script>
  const btn = document.getElementById('nav-hamburger');
  const menu = document.getElementById('nav-links');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
    // close on any nav link click
    menu.querySelectorAll('a').forEach(a =>
      a.addEventListener('click', () => {
        menu.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      })
    );
  }

  // Schedule Tabs
  const tabBtns = document.querySelectorAll('.tab-btn');
  const panes = document.querySelectorAll('.schedule-day-pane');
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const dayIdx = btn.getAttribute('data-day');
      
      // Update buttons
      tabBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      // Update panes
      panes.forEach(p => p.classList.remove('active'));
      const activePane = document.getElementById(`day-pane-${dayIdx}`);
      if (activePane) activePane.classList.add('active');
    });
  });
</script>

<style>
  /* ── Layout ── */
  .container {
    max-width: 68.75rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Nav ── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(0, 37, 122, 0.97);
    backdrop-filter: blur(0.75rem);
    border-bottom: 0.0625rem solid rgba(255,255,255,0.08);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }
  .brand-apnic { color: #fff; }
  .brand-sep { color: rgba(255,255,255,0.4); }
  .brand-twnog { color: #7EC8E3; }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }
  .nav-links a {
    padding: 0.375rem 0.875rem;
    border-radius: 0.5rem;
    color: rgba(255,255,255,0.8);
    font-size: 0.8rem;
    font-weight: 600;
    transition: color 0.2s, background 0.2s;
    border: 0.0625rem solid transparent;
  }
  .nav-links a:hover { color: #fff; background: rgba(255,255,255,0.1); }
  .lang-toggle, .nav-cta {
    display: flex !important;
    align-items: center;
    justify-content: center;
    gap: 0.3125rem;
    min-width: 6.5rem;
    border: 0.0625rem solid transparent !important;
    letter-spacing: 0.04em;
  }
  .lang-toggle {
    border-color: rgba(255,255,255,0.25) !important;
    background: rgba(255,255,255,0.05) !important;
  }
  .lang-toggle:hover { 
    border-color: rgba(255,255,255,0.6) !important; 
    background: rgba(255,255,255,0.15) !important;
  }
  .nav-cta {
    background: var(--blue-light) !important;
    border-color: var(--blue-light) !important;
    color: #fff !important;
  }
  .nav-cta:hover { 
    background: #00b3f0 !important; 
    border-color: #00b3f0 !important; 
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #00257A 0%, #003DA5 50%, #0054A6 100%);
    overflow: hidden;
    padding-top: 4rem;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 80% 20%, rgba(0,153,214,0.25) 0%, transparent 60%),
      radial-gradient(ellipse 40% 60% at 10% 80%, rgba(0,80,160,0.4) 0%, transparent 60%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    padding: 5rem 1.5rem;
  }
  .hero-badges {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 1.5rem;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.875rem;
    border-radius: 6.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: var(--blue-light);
    color: #fff;
  }
  .badge-outline {
    background: transparent;
    border: 0.09375rem solid rgba(255,255,255,0.4);
    color: rgba(255,255,255,0.9);
  }
  .hero-title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 800;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }
  .hero-title-accent { color: #7EC8E3; }
  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255,255,255,0.75);
    max-width: 35rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }
  .hero-meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
    font-weight: 500;
  }
  .hero-meta-item svg { flex-shrink: 0; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .hero-wave {
    position: absolute;
    bottom: -0.0625rem;
    left: 0;
    right: 0;
    height: 5.625rem;
    overflow: hidden;
  }
  .wave-track {
    position: absolute;
    bottom: 0;
    display: flex;
    width: 200%;
  }
  .wave-track svg {
