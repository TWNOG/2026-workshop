---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
  otherLangHref: string;
  otherLangLabel: string;
  otherLang: string;
}

const { t, otherLangHref, otherLangLabel, otherLang } = Astro.props;
---

<nav class="nav">
  <div class="container nav-inner">
    <div class="nav-brand">
      <span class="brand-apnic">APNIC</span>
      <span class="brand-sep">×</span>
      <span class="brand-twnog">TWNOG 7</span>
    </div>
    <ul class="nav-links" id="nav-links">
      <li><a href="#about">{t.nav.about}</a></li>
      <li><a href="#course">{t.nav.course}</a></li>
      <li><a href="#venue">{t.nav.venue}</a></li>
      <li>
        <a href={otherLangHref} class="lang-toggle" aria-label={`Switch to ${otherLang}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          {otherLangLabel}
        </a>
      </li>
      <li>
        <a href={t.register.kktixHref} class="nav-cta" target="_blank" rel="noopener">
          {t.nav.register}
        </a>
      </li>
    </ul>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<script>
  const btn = document.getElementById('nav-hamburger');
  const menu = document.getElementById('nav-links');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const open = menu.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
    // close on any nav link click
    menu.querySelectorAll('a').forEach(a =>
      a.addEventListener('click', () => {
        menu.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      })
    );
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(0, 37, 122, 0.97);
    backdrop-filter: blur(0.75rem);
    border-bottom: 0.0625rem solid rgba(255,255,255,0.08);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }
  .brand-apnic { color: #fff; }
  .brand-sep { color: rgba(255,255,255,0.4); }
  .brand-twnog { color: #7EC8E3; }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }
  .nav-links a {
    padding: 0.375rem 0.875rem;
    border-radius: 0.5rem;
    color: rgba(255,255,255,0.8);
    font-size: 0.8rem;
    font-weight: 600;
    transition: color 0.2s, background 0.2s;
    border: 0.0625rem solid transparent;
  }
  .nav-links a:hover { color: #fff; background: rgba(255,255,255,0.1); }
  .lang-toggle, .nav-cta {
    display: flex !important;
    align-items: center;
    justify-content: center;
    gap: 0.3125rem;
    min-width: 6.5rem;
    border: 0.0625rem solid transparent !important;
    letter-spacing: 0.04em;
  }
  .lang-toggle {
    border-color: rgba(255,255,255,0.25) !important;
    background: rgba(255,255,255,0.05) !important;
  }
  .lang-toggle:hover { 
    border-color: rgba(255,255,255,0.6) !important; 
    background: rgba(255,255,255,0.15) !important;
  }
  .nav-cta {
    background: var(--blue-light) !important;
    border-color: var(--blue-light) !important;
    color: #fff !important;
  }
  .nav-cta:hover { 
    background: #00b3f0 !important; 
    border-color: #00b3f0 !important; 
  }
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 0.3125rem;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0.5rem;
    border-radius: 0.5rem;
    background: transparent;
    border: 0.0625rem solid rgba(255,255,255,0.25);
    cursor: pointer;
    flex-shrink: 0;
  }
  .nav-hamburger span {
    display: block;
    height: 0.125rem;
    background: #fff;
    border-radius: 0.125rem;
    transition: transform 0.25s, opacity 0.25s;
    transform-origin: center;
  }
  .nav-hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(0.4375rem) rotate(45deg); }
  .nav-hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .nav-hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-0.4375rem) rotate(-45deg); }

  @media (max-width: 48rem) {
    .nav-hamburger { display: flex; }
    .nav-links {
      display: none;
      position: absolute;
      top: 4rem;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background: rgba(0, 25, 90, 0.98);
      backdrop-filter: blur(1rem);
      border-top: 0.0625rem solid rgba(255,255,255,0.08);
      padding: 0.5rem 1rem 1rem;
    }
    .nav-links.open { display: flex; }
    .nav-links li { width: 100%; }
    .nav-links a {
      display: block;
      padding: 0.75rem 0.5rem;
      border-radius: 0.5rem;
      border-bottom: 0.0625rem solid rgba(255,255,255,0.06);
      font-size: 1rem;
    }
    .nav-links li:last-child a { border-bottom: none; }
    .nav-cta { margin-top: 0.5rem; text-align: center; }
  }
</style>
