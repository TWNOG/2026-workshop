---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section class="section" id="venue">
  <div class="container">
    <div class="section-header">
      <span class="section-label">{t.venue.label}</span>
      <h2 class="section-title">{t.venue.title}</h2>
    </div>
    <div class="venue-grid">
      <div class="venue-info">
        <div class="venue-card">
          <h3>{t.venue.name}</h3>
          <p class="venue-address">{t.venue.address}</p>
          <div class="venue-details">
            <div class="venue-detail">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
              <span>{t.venue.transport1}</span>
            </div>
            <div class="venue-detail">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>{t.venue.transport2}</span>
            </div>
          </div>
        </div>
      </div>
      <div class="venue-map">
        <div class="map-embed-wrap">
          <iframe
            src="https://maps.google.com/maps?q=25.0408601,121.5206807&hl=zh-TW&z=16&output=embed"
            title={t.venue.name}
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <a
          href="https://www.google.com/maps/search/?api=1&query=25.0408601%2C121.5206807"
          target="_blank"
          rel="noopener"
          class="map-link-ext"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          {t.venue.mapLink}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .venue-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start; }
  .venue-card {
    background: #fff;
    border: 0.0625rem solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: var(--shadow);
  }
  .venue-card h3 { font-size: 1.2rem; font-weight: 700; color: var(--blue-dark); margin-bottom: 0.5rem; }
  .venue-address { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; line-height: 1.6; }
  .venue-details { display: flex; flex-direction: column; gap: 0.875rem; }
  .venue-detail {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .venue-detail svg { flex-shrink: 0; color: var(--blue-light); margin-top: 0.0625rem; }
  .map-embed-wrap {
    border-radius: var(--radius);
    overflow: hidden;
    border: 0.0625rem solid var(--border);
    box-shadow: var(--shadow);
    height: 20rem;
  }
  .map-embed-wrap iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .map-link-ext {
    display: inline-flex;
    align-items: center;
    gap: 0.3125rem;
    margin-top: 0.625rem;
    color: var(--blue-light);
    font-size: 0.83rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
  }
  .map-link-ext:hover { color: var(--blue-mid); text-decoration: underline; }

  @media (max-width: 48rem) {
    .venue-grid { grid-template-columns: 1fr; }
  }
</style>
