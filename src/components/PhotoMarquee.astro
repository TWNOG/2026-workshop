---
interface Props {
  images: string[];
  widths: number[];
  direction?: 'left' | 'right';
  variant?: 'white' | 'alt';
}

const { images, widths, direction = 'left', variant = 'white' } = Astro.props;
---

<div class={`photo-marquee marquee-on-${variant}`}>
  <div class={`marquee-track marquee-${direction}`}>
    {images.map((src, i) => (
      <div class="marquee-item" style={`width:${widths[i % widths.length] / 16}rem`}>
        <img src={src} alt="" loading="lazy" />
      </div>
    ))}
  </div>
</div>

<style>
  .photo-marquee {
    overflow: hidden;
    padding: 2.5rem 0;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 7%, black 93%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 7%, black 93%, transparent 100%);
  }
  .marquee-on-white { background: var(--bg); }
  .marquee-on-alt   { background: var(--bg-alt); }

  .marquee-track {
    display: flex;
    gap: 0.875rem;
    width: max-content;
  }
  .marquee-left  { animation: mq-left  38s linear infinite; }
  .marquee-right { animation: mq-right 30s linear infinite; }

  @keyframes mq-left  { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @keyframes mq-right { from { transform: translateX(-50%); } to { transform: translateX(0); } }

  .marquee-item {
    height: 13.75rem;
    flex-shrink: 0;
    border-radius: 0.625rem;
    background: var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #b0c4d8;
    overflow: hidden;
    transition: background 0.25s;
  }
  .marquee-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .marquee-item:hover { background: #cddbe8; }

  @media (max-width: 48rem) {
    .marquee-item { height: 10rem; }
  }
</style>
